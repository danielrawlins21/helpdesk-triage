# Chat provider configuration
VITE_CHAT_PROVIDER=ollama
VITE_OLLAMA_CHAT_PROXY_URL=http://127.0.0.1:8787/api/chat
VITE_BEDROCK_CHAT_PROXY_URL=http://127.0.0.1:8788/api/chat

# Ollama proxy
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_PROXY_HOST=127.0.0.1
OLLAMA_PROXY_PORT=8787
OLLAMA_MODEL=gemma3:latest
OLLAMA_PROXY_TIMEOUT_MS=60000

# Bedrock proxy
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_PROXY_HOST=127.0.0.1
BEDROCK_PROXY_PORT=8788
BEDROCK_PROXY_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
BEDROCK_PROXY_TIMEOUT_MS=60000
BEDROCK_MAX_TOKENS=300
BEDROCK_TEMPERATURE=0.4
